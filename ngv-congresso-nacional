// CONTAS
// =========================================================

app.post("/cadastro",async(req,res)=>{

const {nome,user,senha} = req.body

const conta={
id:uuid(),
nome,
user,
senha,
role:"visitante",
foto:"",
banner:"",
descricao:""
}

db.data.contas.push(conta)
await db.write()

res.json(conta)

})

app.post("/login",async(req,res)=>{

const {user,senha} = req.body

const conta=db.data.contas.find(
c=>c.user===user && c.senha===senha
)

if(!conta){
return res.status(401).json({erro:"login inválido"})
}

res.json(conta)

})

