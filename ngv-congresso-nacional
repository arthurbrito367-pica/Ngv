<script>

/* ========================================================= */
/* BANCO LOCAL                                               */
/* ========================================================= */

let comissoes = JSON.parse(localStorage.getItem("comissoes") || "[]")
let legislaturas = JSON.parse(localStorage.getItem("legislaturas") || "[]")
let historico = JSON.parse(localStorage.getItem("historico") || "[]")

function saveAll(){

localStorage.setItem("comissoes",JSON.stringify(comissoes))
localStorage.setItem("legislaturas",JSON.stringify(legislaturas))
localStorage.setItem("historico",JSON.stringify(historico))

}

/* ========================================================= */
/* COMISSÕES LEGISLATIVAS                                    */
/* ========================================================= */

function criarComissao(){

let nome = document.getElementById("comissaoNome").value

let comissao = {

id:Date.now(),
nome,
membros:[],
projetos:[],
reunioes:[]

}

comissoes.push(comissao)

saveAll()

renderComissoes()

}

function entrarComissao(id){

let comissao = comissoes.find(c=>c.id===id)

if(!comissao.membros.includes(usuarioAtual.id)){
comissao.membros.push(usuarioAtual.id)
}

saveAll()

renderComissoes()

}

function enviarProjetoComissao(comissaoID,projetoID){

let c = comissoes.find(x=>x.id===comissaoID)

if(!c.projetos.includes(projetoID)){
c.projetos.push(projetoID)
}

registrarHistorico("Projeto "+projetoID+" enviado para comissão "+c.nome)

saveAll()

}

function renderComissoes(){

let el = document.getElementById("listaComissoes")
if(!el) return

el.innerHTML=""

comissoes.forEach(c=>{

el.innerHTML+=`

<div class="card">

<h3>${c.nome}</h3>

Membros: ${c.membros.length}

<br>

Projetos: ${c.projetos.length}

<br><br>

<button onclick="entrarComissao(${c.id})">Entrar</button>

</div>

`

})

}

/* ========================================================= */
/* TRAMITAÇÃO ENTRE CASAS                                    */
/* ========================================================= */

function enviarParaCamara(projetoID){

let p = projetos.find(x=>x.id===projetoID)

p.status="Câmara dos Deputados"

registrarHistorico("Projeto "+p.titulo+" enviado à Câmara")

DB.save("projetos",projetos)

}

function enviarParaSenado(projetoID){

let p = projetos.find(x=>x.id===projetoID)

p.status="Senado Federal"

registrarHistorico("Projeto "+p.titulo+" enviado ao Senado")

DB.save("projetos",projetos)

}

function enviarParaPresidente(projetoID){

let p = projetos.find(x=>x.id===projetoID)

p.status="Presidência da República"

registrarHistorico("Projeto "+p.titulo+" enviado ao Presidente")

DB.save("projetos",projetos)

}

function sancionarProjeto(projetoID){

let p = projetos.find(x=>x.id===projetoID)

p.status="Lei sancionada"

registrarHistorico("Projeto "+p.titulo+" sancionado")

DB.save("projetos",projetos)

}

function vetarProjeto(projetoID){

let p = projetos.find(x=>x.id===projetoID)

p.status="Veto presidencial"

registrarHistorico("Projeto "+p.titulo+" vetado")

DB.save("projetos",projetos)

}

/* ========================================================= */
/* HISTÓRICO LEGISLATIVO                                     */
/* ========================================================= */

function registrarHistorico(texto){

historico.push({

id:Date.now(),
texto,
data:new Date().toLocaleString()

})

saveAll()

renderHistorico()

}

function renderHistorico(){

let el = document.getElementById("historico")

if(!el) return

el.innerHTML=""

historico.slice().reverse().forEach(h=>{

el.innerHTML+=`

<div class="card">

${h.texto}

<br>

<small>${h.data}</small>

</div>

`

})

}

/* ========================================================= */
/* LEGISLATURAS                                              */
/* ========================================================= */

function criarLegislatura(){

let anoInicio=document.getElementById("legInicio").value
let anoFim=document.getElementById("legFim").value

let leg={

id:Date.now(),
inicio:anoInicio,
fim:anoFim,
parlamentares:[]

}

legislaturas.push(leg)

saveAll()

}

function registrarParlamentarLegislatura(id){

let leg=legislaturas[legislaturas.length-1]

if(!leg.parlamentares.includes(id)){
leg.parlamentares.push(id)
}

saveAll()

}

/* ========================================================= */
/* PLENÁRIO VISUAL                                           */
/* ========================================================= */

function renderPlenario(){

let el=document.getElementById("plenarioMapa")

if(!el) return

el.innerHTML=""

parlamentares.forEach(p=>{

let voto = votos.find(v=>v.usuario===p.id)

let cor="#ddd"

if(voto){

if(voto.voto==="SIM") cor="green"
if(voto.voto==="NAO") cor="red"
if(voto.voto==="ABS") cor="yellow"

}

el.innerHTML+=`

<div style="
