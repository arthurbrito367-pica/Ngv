<!-- ========================================================= -->
<!-- NGv – SIMULAÇÃO EDUCACIONAL DO CONGRESSO NACIONAL DO BRASIL -->
<!-- Sistema institucional fictício completo -->
<!-- Estrutura pensada para funcionar localmente e em GitHub -->
<!-- ========================================================= -->

<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Congresso Nacional — NGv</title>

<style>

/* ============================= */
/* ESTILO GLOBAL MINIMALISTA    */
/* ============================= */

body{
font-family: "Segoe UI", Arial, sans-serif;
margin:0;
background:#f4f7f4;
color:#222;
}

header{
background:#0b6e3f;
color:white;
padding:12px;
display:flex;
align-items:center;
justify-content:space-between;
}

header img{
height:40px;
}

nav{
background:white;
display:flex;
gap:10px;
padding:10px;
border-bottom:1px solid #ddd;
overflow-x:auto;
}

nav button{
background:#fff;
border:1px solid #ccc;
padding:8px 12px;
cursor:pointer;
border-radius:6px;
}

nav button:hover{
background:#e6f4ea;
}

.container{
display:flex;
height:calc(100vh - 110px);
}

.sidebar{
width:260px;
background:#ffffff;
border-right:1px solid #ddd;
overflow:auto;
padding:10px;
}

.main{
flex:1;
padding:20px;
overflow:auto;
}

.card{
background:white;
border:1px solid #ddd;
border-radius:8px;
padding:15px;
margin-bottom:15px;
}

.card.red{
border-left:6px solid red;
}

.card.green{
border-left:6px solid green;
}

input,select,textarea{
width:100%;
padding:8px;
margin-top:6px;
margin-bottom:10px;
border:1px solid #ccc;
border-radius:6px;
}

button.primary{
background:#0b6e3f;
color:white;
border:none;
padding:10px 16px;
border-radius:6px;
cursor:pointer;
}

button.primary:hover{
background:#095a34;
}

.profile{
display:flex;
gap:10px;
align-items:center;
}

.profile img{
width:50px;
height:50px;
border-radius:50%;
object-fit:cover;
}

.tag{
background:#ffd200;
padding:2px 6px;
border-radius:4px;
font-size:12px;
}

.message{
padding:10px;
border-radius:10px;
margin:5px 0;
background:#f1f1f1;
}

.message.me{
background:#d7f7e0;
}

.session-panel{
display:flex;
gap:10px;
flex-wrap:wrap;
}

.vote-btn{
padding:10px;
border-radius:6px;
border:1px solid #ccc;
cursor:pointer;
}

.vote-yes{background:#d7f7e0}
.vote-no{background:#ffdcdc}
.vote-abs{background:#f7f7d7}

.hidden{display:none}

</style>
</head>

<body>

<header>

<div style="display:flex;align-items:center;gap:10px;">
<img src="https://upload.wikimedia.org/wikipedia/commons/1/1b/Bras%C3%A3o_da_Republica_Federativa_do_Brasil.svg">
<strong>Congresso Nacional — NGv</strong>
</div>

<div id="userStatus">Visitante</div>

</header>

<nav>

<button onclick="showTab('home')">Início</button>
<button onclick="showTab('camara')">Câmara</button>
<button onclick="showTab('projetos')">Projetos</button>
<button onclick="showTab('plenário')">Plenário Virtual</button>
<button onclick="showTab('gabinetes')">Gabinetes</button>
<button onclick="showTab('forum')">Fórum</button>
<button onclick="showTab('perfil')">Perfil</button>
<button onclick="showTab('admin')">Admin</button>

</nav>

<div class="container">

<div class="sidebar">

<div class="card">
<h3>Notificações</h3>
<div id="notificacoes"></div>
</div>

<div class="card">
<h3>Estados</h3>

<img width="30" src="https://upload.wikimedia.org/wikipedia/commons/5/59/Bandeira_de_S%C3%A3o_Paulo.svg">
São Paulo<br>

<img width="30" src="https://upload.wikimedia.org/wikipedia/commons/8/88/Bandeira_de_Pernambuco.svg">
Pernambuco<br>

<img width="30" src="https://upload.wikimedia.org/wikipedia/commons/6/63/Bandeira_do_Rio_Grande_do_Sul.svg">
Rio Grande do Sul<br>

<img width="30" src="https://upload.wikimedia.org/wikipedia/commons/6/6b/Bandeira_do_Amazonas.svg">
Amazonas<br>

<img width="30" src="https://upload.wikimedia.org/wikipedia/commons/b/bb/Bandeira_de_Goi%C3%A1s.svg">
Goiás

</div>

</div>

<div class="main">

<!-- ================= HOME ================= -->

<div id="home">

<div class="card">
<h2>Convocações</h2>
<div id="convocacoes"></div>
</div>

<div class="card">
<h2>Avisos</h2>
<div id="avisos"></div>
</div>

</div>

<!-- ================= CAMARA ================= -->

<div id="camara" class="hidden">

<div class="card">
<h2>Cadastro de Parlamentar</h2>

<input id="nomeParlamentar" placeholder="Nome">
<input id="fotoParlamentar" placeholder="URL da foto">
<select id="cargoParlamentar">
<option>Deputado</option>
<option>Senador</option>
<option>Governador</option>
<option>Presidente</option>
<option>Vice-Presidente</option>
</select>

<button class="primary" onclick="cadastrarParlamentar()">Cadastrar</button>

</div>

<div id="listaParlamentares"></div>

</div>

<!-- ================= PROJETOS ================= -->

<div id="projetos" class="hidden">

<div class="card">

<h2>Novo Projeto</h2>

<input id="tituloProjeto" placeholder="Título">

<select id="tipoProjeto">
<option>Projeto de Lei Ordinária (PL)</option>
<option>Proposta de Emenda à Constituição (PEC)</option>
<option>Projeto de Decreto Legislativo (PDL)</option>
<option>Projeto de Lei Complementar (PLP)</option>
<option>Projeto de Resolução (PR)</option>
<option>Requerimento de Comissão (RC)</option>
<option>Requerimento de Informação (RI)</option>
<option>Requerimento de Instituição de CPI</option>
<option>Emenda ao Orçamento</option>
<option>Orçamento</option>
<option>Indicação</option>
<option>Outros</option>
</select>

<input type="file" id="arquivoProjeto">

<button class="primary" onclick="criarProjeto()">Protocolar</button>

</div>

<div id="listaProjetos"></div>

</div>

<!-- ================= PLENARIO ================= -->

<div id="plenário" class="hidden">

<div class="card">
<h2>Iniciar Sessão</h2>

<input id="tituloSessao" placeholder="Título da Sessão">

<button class="primary" onclick="iniciarSessao()">Iniciar</button>

</div>

<div id="sessaoAtual"></div>

</div>

<!-- ================= GABINETES ================= -->

<div id="gabinetes" class="hidden">

<div class="card">
<h2>Gabinetes</h2>

<input id="nomeGabinete" placeholder="Nome do Gabinete">

<button class="primary" onclick="criarGabinete()">Criar</button>

</div>

<div id="listaGabinetes"></div>

</div>

<!-- ================= FORUM ================= -->

<div id="forum" class="hidden">

<div class="card">
<h2>Grupos</h2>

<input id="nomeGrupo" placeholder="Nome do Grupo">
<button class="primary" onclick="criarGrupo()">Criar</button>

</div>

<div id="listaGrupos"></div>

</div>

<!-- ================= PERFIL ================= -->

<div id="perfil" class="hidden">

<div class="card">

<h2>Editar Perfil</h2>

<input id="perfilFoto" placeholder="URL da Foto">
<input id="perfilBanner" placeholder="URL do Banner">
<input id="perfilDescricao" placeholder="Descrição">

<button class="primary" onclick="salvarPerfil()">Salvar</button>

</div>

<div id="perfilView"></div>

</div>

<!-- ================= ADMIN ================= -->

<div id="admin" class="hidden">

<div class="card">

<h2>Login Administrador</h2>

<input id="adminUser">
<input id="adminPass" type="password">

<button class="primary" onclick="loginAdmin()">Entrar</button>

</div>

<div id="adminPanel"></div>

</div>

</div>
</div>

<script>

/* ================= BANCO LOCAL ================= */

let users=JSON.parse(localStorage.getItem("users")||"[]")
let projetos=JSON.parse(localStorage.getItem("projetos")||"[]")
let parlamentares=JSON.parse(localStorage.getItem("parlamentares")||"[]")
let sessoes=JSON.parse(localStorage.getItem("sessoes")||"[]")
let gabinetes=JSON.parse(localStorage.getItem("gabinetes")||"[]")
let grupos=JSON.parse(localStorage.getItem("grupos")||"[]")

function save(){
localStorage.setItem("users",JSON.stringify(users))
localStorage.setItem("projetos",JSON.stringify(projetos))
localStorage.setItem("parlamentares",JSON.stringify(parlamentares))
localStorage.setItem("sessoes",JSON.stringify(sessoes))
localStorage.setItem("gabinetes",JSON.stringify(gabinetes))
localStorage.setItem("grupos",JSON.stringify(grupos))
}

/* ================= TABS ================= */

function showTab(id){
document.querySelectorAll(".main>div").forEach(e=>e.classList.add("hidden"))
document.getElementById(id).classList.remove("hidden")
}

/* ================= PARLAMENTARES ================= */

function cadastrarParlamentar(){

let p={
id:Date.now(),
nome:nomeParlamentar.value,
foto:fotoParlamentar.value,
cargo:cargoParlamentar.value
}

parlamentares.push(p)
save()
renderParlamentares()

}

function renderParlamentares(){

let el=document.getElementById("listaParlamentares")
el.innerHTML=""

parlamentares.forEach(p=>{

el.innerHTML+=`
<div class="card profile">
<img src="${p.foto}">
<div>
<strong>${p.nome}</strong><br>
<span class="tag">${p.cargo}</span>
</div>
</div>
`

})

}

renderParlamentares()

/* ================= PROJETOS ================= */

function criarProjeto(){

let file=document.getElementById("arquivoProjeto").files[0]

let projeto={
id:Date.now(),
titulo:tituloProjeto.value,
tipo:tipoProjeto.value,
file:file?URL.createObjectURL(file):null
}

projetos.push(projeto)
save()
renderProjetos()

}

function renderProjetos(){

let el=document.getElementById("listaProjetos")
el.innerHTML=""

projetos.forEach(p=>{

el.innerHTML+=`
<div class="card green">
<h3>${p.titulo}</h3>
${p.tipo}<br>
${p.file?`<a href="${p.file}" target="_blank">Abrir Documento</a>`:""}
</div>
`

})

}

renderProjetos()

/* ================= SESSÃO ================= */

function iniciarSessao(){

let s={
id:Date.now(),
titulo:tituloSessao.value,
votos:[]
}

sessoes.push(s)
save()
renderSessao(s)

}

function renderSessao(s){

let el=document.getElementById("sessaoAtual")

el.innerHTML=`
<div class="card">
<h2>${s.titulo}</h2>

<div class="session-panel">

<button class="vote-btn vote-yes" onclick="votar('SIM')">Favorável</button>
<button class="vote-btn vote-no" onclick="votar('NAO')">Contrário</button>
<button class="vote-btn vote-abs" onclick="votar('ABS')">Abstenção</button>

</div>

<div id="votos"></div>

</div>
`

}

function votar(v){

let s=sessoes[sessoes.length-1]
s.votos.push(v)
save()

document.getElementById("votos").innerHTML="Votos: "+s.votos.join(", ")

}

/* ================= GABINETES ================= */

function criarGabinete(){

let g={
id:Date.now(),
nome:nomeGabinete.value,
msgs:[]
}

gabinetes.push(g)
save()
renderGabinetes()

}

function renderGabinetes(){

let el=document.getElementById("listaGabinetes")
el.innerHTML=""

gabinetes.forEach(g=>{

el.innerHTML+=`
<div class="card">
<h3>${g.nome}</h3>
<textarea id="msg${g.id}"></textarea>
<button onclick="msgGab(${g.id})">Enviar</button>
<div id="chat${g.id}"></div>
</div>
`

})

}

function msgGab(id){

let g=gabinetes.find(x=>x.id==id)

let t=document.getElementById("msg"+id).value

g.msgs.push(t)
save()

document.getElementById("chat"+id).innerHTML+=`<div class="message">${t}</div>`

}

renderGabinetes()

/* ================= GRUPOS ================= */

function criarGrupo(){

let g={
id:Date.now(),
nome:nomeGrupo.value,
msgs:[]
}

grupos.push(g)
save()
renderGrupos()

}

function renderGrupos(){

let el=document.getElementById("listaGrupos")
el.innerHTML=""

grupos.forEach(g=>{

el.innerHTML+=`
<div class="card">
<h3>${g.nome}</h3>
<textarea id="gmsg${g.id}"></textarea>
<button onclick="msgGrupo(${g.id})">Enviar</button>
<div id="gchat${g.id}"></div>
</div>
`

})

}

function msgGrupo(id){

let g=grupos.find(x=>x.id==id)

let t=document.getElementById("gmsg"+id).value

g.msgs.push(t)
save()

document.getElementById("gchat"+id).innerHTML+=`<div class="message">${t}</div>`

}

renderGrupos()

/* ================= PERFIL ================= */

function salvarPerfil(){

let p={
foto:perfilFoto.value,
banner:perfilBanner.value,
desc:perfilDescricao.value
}

localStorage.setItem("perfil",JSON.stringify(p))
renderPerfil()

}

function renderPerfil(){

let p=JSON.parse(localStorage.getItem("perfil")||"{}")

let el=document.getElementById("perfilView")

el.innerHTML=`
<div class="card">
<img src="${p.banner}" style="width:100%">
<div class="profile">
<img src="${p.foto}">
<div>${p.desc||""}</div>
</div>
</div>
`

}

renderPerfil()

/* ================= ADMIN ================= */

function loginAdmin(){

if(adminUser.value=="CongressoNacional.org" && adminPass.value=="777.cn"){

adminPanel.innerHTML=`
<div class="card">
<h2>Painel Admin</h2>
<button onclick="reset()">Resetar Sistema</button>
</div>
`

}

}

function reset(){

localStorage.clear()
location.reload()

}

</script>

</body>
</html>
<!-- ========================================================= -->
<!-- NGv – CONGRESSO NACIONAL SIMULAÇÃO EDUCACIONAL -->
<!-- PARTE 2 – SISTEMA COMPLETO DE CONTAS, AUTENTICAÇÃO, ROLES -->
<!-- BANCO LOCAL + MOTOR LEGISLATIVO EXPANDIDO -->
<!-- ========================================================= -->

<script>

/* ========================================================= */
/* SISTEMA DE BANCO DE DADOS LOCAL PERSISTENTE               */
/* ========================================================= */

const DB = {

load(key){
return JSON.parse(localStorage.getItem(key) || "[]")
},

save(key,data){
localStorage.setItem(key,JSON.stringify(data))
}

}

let contas = DB.load("contas")
let projetos = DB.load("projetos")
let parlamentares = DB.load("parlamentares")
let sessoes = DB.load("sessoes")
let notificacoes = DB.load("notificacoes")
let tramites = DB.load("tramites")
let votos = DB.load("votos")
let presencas = DB.load("presencas")
let pronunciamentos = DB.load("pronunciamentos")

let usuarioAtual = JSON.parse(localStorage.getItem("usuarioAtual") || "null")

/* ========================================================= */
/* ENUM DE CARGOS                                            */
/* ========================================================= */

const ROLES = {
VISITANTE:"visitante",
DEPUTADO:"deputado",
SENADOR:"senador",
GOVERNADOR:"governador",
PRESIDENTE:"presidente",
VICE:"vice",
ADMIN:"admin"
}

/* ========================================================= */
/* LOGIN E CADASTRO                                          */
/* ========================================================= */

function cadastrarConta(){

let nome = document.getElementById("cadNome").value
let user = document.getElementById("cadUser").value
let senha = document.getElementById("cadSenha").value

let conta = {

id:Date.now(),
nome,
user,
senha,
role:ROLES.VISITANTE,
foto:"",
banner:"",
descricao:"",
selo:"",
seguidores:[],
seguindo:[],
curtidas:[],
projetos:[],
presencas:[],
votos:[]

}

contas.push(conta)
DB.save("contas",contas)

alert("Conta criada")

}

function login(){

let user = document.getElementById("loginUser").value
let senha = document.getElementById("loginSenha").value

let conta = contas.find(c=>c.user===user && c.senha===senha)

if(!conta){
alert("login inválido")
return
}

usuarioAtual = conta
localStorage.setItem("usuarioAtual",JSON.stringify(conta))

atualizarInterface()

}

function logout(){

usuarioAtual=null
localStorage.removeItem("usuarioAtual")
location.reload()

}

/* ========================================================= */
/* ATUALIZA INTERFACE                                        */
/* ========================================================= */

function atualizarInterface(){

let el = document.getElementById("userStatus")

if(!usuarioAtual){
el.innerText="Visitante"
return
}

el.innerText=usuarioAtual.nome + " ("+usuarioAtual.role+")"

}

/* ========================================================= */
/* SISTEMA DE PARLAMENTARES                                  */
/* ========================================================= */

function registrarParlamentar(){

if(!usuarioAtual) return

let cargo = document.getElementById("cargoRegistro").value

usuarioAtual.role=cargo

let parlamentar = {

id:usuarioAtual.id,
nome:usuarioAtual.nome,
cargo:cargo,
foto:usuarioAtual.foto,
estado:"",
partido:"",
projetos:[],
presencas:[],
votos:[]

}

parlamentares.push(parlamentar)

DB.save("parlamentares",parlamentares)

}

/* ========================================================= */
/* PROJETOS LEGISLATIVOS                                     */
/* ========================================================= */

function protocolarProjeto(){

if(!usuarioAtual) return

let titulo=document.getElementById("projTitulo").value
let tipo=document.getElementById("projTipo").value
let urgencia=document.getElementById("projUrgencia").checked

let arquivo=document.getElementById("projArquivo").files[0]

let url=null

if(arquivo){
url=URL.createObjectURL(arquivo)
}

let projeto={

id:Date.now(),
autor:usuarioAtual.id,
titulo,
tipo,
urgencia,
arquivo:url,
status:"Protocolado",
tramite:[],
data:new Date().toLocaleString()

}

projetos.push(projeto)

usuarioAtual.projetos.push(projeto.id)

DB.save("projetos",projetos)
DB.save("contas",contas)

renderProjetos()

}

/* ========================================================= */
/* TRAMITAÇÃO                                                */
/* ========================================================= */

function registrarTramite(id,texto){

let projeto=projetos.find(p=>p.id===id)

projeto.tramite.push({

data:new Date().toLocaleString(),
descricao:texto

})

DB.save("projetos",projetos)

renderProjetos()

}

/* ========================================================= */
/* LISTAGEM DE PROJETOS                                      */
/* ========================================================= */

function renderProjetos(){

let el=document.getElementById("listaProjetos")

if(!el) return

el.innerHTML=""

projetos.forEach(p=>{

let cor = p.urgencia ? "red":"green"

el.innerHTML+=`

<div class="card ${cor}">

<h3>${p.titulo}</h3>

<strong>${p.tipo}</strong>

<br>

Autor: ${buscarNome(p.autor)}

<br><br>

${p.arquivo ? `<a href="${p.arquivo}" target="_blank">Documento</a>`:""}

<button onclick="abrirProjeto(${p.id})">Ver</button>

</div>

`

})

}

/* ========================================================= */
/* ABRIR PROJETO                                             */
/* ========================================================= */

function abrirProjeto(id){

let projeto=projetos.find(p=>p.id===id)

let html=`

<h2>${projeto.titulo}</h2>

<p>${projeto.tipo}</p>

<h3>Tramitação</h3>

`

projeto.tramite.forEach(t=>{

html+=`<p>${t.data} — ${t.descricao}</p>`

})

document.getElementById("detalheProjeto").innerHTML=html

}

/* ========================================================= */
/* SESSÕES LEGISLATIVAS                                      */
/* ========================================================= */

function criarSessao(){

if(!usuarioAtual) return

let titulo=document.getElementById("sessaoTitulo").value

let sessao={

id:Date.now(),
titulo,
presencas:[],
votos:[],
projetos:[],
inicio:new Date().toLocaleString(),
encerrada:false

}

sessoes.push(sessao)

DB.save("sessoes",sessoes)

renderSessaoAtual()

}

/* ========================================================= */
/* PRESENÇA                                                  */
/* ========================================================= */

function registrarPresenca(status){

if(!usuarioAtual) return

let sessao=sessoes[sessoes.length-1]

sessao.presencas.push({

usuario:usuarioAtual.id,
status

})

presencas.push({

usuario:usuarioAtual.id,
sessao:sessao.id,
status

})

DB.save("sessoes",sessoes)
DB.save("presencas",presencas)

}

/* ========================================================= */
/* VOTAÇÃO                                                   */
/* ========================================================= */

function votarProjeto(id,voto){

if(!usuarioAtual) return

let registro={

usuario:usuarioAtual.id,
projeto:id,
voto,
data:new Date().toLocaleString()

}

votos.push(registro)

usuarioAtual.votos.push(registro)

DB.save("votos",votos)
DB.save("contas",contas)

}

/* ========================================================= */
/* PLENÁRIO VIRTUAL                                          */
/* ========================================================= */

function renderSessaoAtual(){

let el=document.getElementById("sessaoAtual")

let s=sessoes[sessoes.length-1]

if(!s) return

el.innerHTML=`

<h2>${s.titulo}</h2>

<button onclick="registrarPresenca('presente')">Presente</button>
<button onclick="registrarPresenca('ausente')">Ausente</button>
<button onclick="registrarPresenca('atrasado')">Atrasado</button>

<h3>Projetos em pauta</h3>

<div id="pauta"></div>

`

renderPauta()

}

function renderPauta(){

let el=document.getElementById("pauta")

el.innerHTML=""

projetos.forEach(p=>{

el.innerHTML+=`

<div class="card">

${p.titulo}

<button onclick="votarProjeto(${p.id},'SIM')">SIM</button>
<button onclick="votarProjeto(${p.id},'NAO')">NÃO</button>
<button onclick="votarProjeto(${p.id},'ABS')">ABS</button>

</div>

`

})

}

/* ========================================================= */
/* PRONUNCIAMENTOS                                           */
/* ========================================================= */

function publicarPronunciamento(){

if(!usuarioAtual) return

let texto=document.getElementById("textoPronunciamento").value
let video=document.getElementById("videoPronunciamento").value

let post={

id:Date.now(),
autor:usuarioAtual.id,
texto,
video,
curtidas:[],
data:new Date().toLocaleString()

}

pronunciamentos.push(post)

DB.save("pronunciamentos",pronunciamentos)

renderPronunciamentos()

}

function curtirPronunciamento(id){

let post=pronunciamentos.find(p=>p.id===id)

post.curtidas.push(usuarioAtual.id)

DB.save("pronunciamentos",pronunciamentos)

renderPronunciamentos()

}

function renderPronunciamentos(){

let el=document.getElementById("listaPronunciamentos")

if(!el) return

el.innerHTML=""

pronunciamentos.forEach(p=>{

el.innerHTML+=`

<div class="card">

<strong>${buscarNome(p.autor)}</strong>

<p>${p.texto}</p>

${p.video ? `<iframe width="100%" src="${p.video}"></iframe>`:""}

<button onclick="curtirPronunciamento(${p.id})">Curtir (${p.curtidas.length})</button>

</div>

`

})

}

/* ========================================================= */
/* UTILIDADES                                                */
/* ========================================================= */

function buscarNome(id){

let u=contas.find(c=>c.id===id)

return u ? u.nome : "Desconhecido"

}

