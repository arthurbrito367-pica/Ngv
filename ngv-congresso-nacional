// PROJETOS
// =========================================================

app.post("/projetos",upload.single("arquivo"),async(req,res)=>{

const {titulo,tipo,autor,urgencia}=req.body

const projeto={

id:uuid(),
titulo,
tipo,
autor,
urgencia,
arquivo:req.file?req.file.path:null,
tramite:[],
data:new Date()

}

db.data.projetos.push(projeto)

await db.write()

res.json(projeto)

})

app.get("/projetos",async(req,res)=>{

res.json(db.data.projetos)

})

// =========================================================
// SESSÕES
// =========================================================

app.post("/sessao",async(req,res)=>{

const {titulo}=req.body

const sessao={

id:uuid(),
titulo,
presencas:[],
votos:[],
inicio:new Date(),
encerrada:false

}

db.data.sessoes.push(sessao)

await db.write()

io.emit("novaSessao",sessao)

res.json(sessao)

})

// =========================================================
// PRESENÇA
// =========================================================

app.post("/presenca",async(req,res)=>{

const {sessao,usuario,status}=req.body

const registro={

id:uuid(),
sessao,
usuario,
status

}

db.data.presencas.push(registro)

await db.write()

io.emit("presenca",registro)

res.json(registro)

})

// =========================================================
// VOTAÇÃO
// =========================================================

app.post("/voto",async(req,res)=>{

const {projeto,usuario,voto}=req.body

const registro={

id:uuid(),
projeto,
usuario,
voto

}

db.data.votos.push(registro)

await db.write()

io.emit("voto",registro)

res.json(registro)

})

// =========================================================
// POSTS / PRONUNCIAMENTOS
// =========================================================

app.post("/post",async(req,res)=>{

const {autor,texto,video}=req.body

const post={

id:uuid(),
autor,
texto,
video,
curtidas:[],
data:new Date()

}

db.data.posts.push(post)

await db.write()

io.emit("novoPost",post)

res.json(post)

})

// =========================================================
// CURTIDAS
// =========================================================

app.post("/curtir",async(req,res)=>{

const {post,usuario}=req.body

const p=db.data.posts.find(x=>x.id===post)

if(!p.curtidas.includes(usuario)){
p.curtidas.push(usuario)
}

