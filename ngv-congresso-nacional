<script>

/* ========================================================= */
/* BANCO                                                     */
/* ========================================================= */

let partidos = DB.load("partidos")
let bancadas = DB.load("bancadas")
let mesaDiretora = DB.load("mesaDiretora")
let eleicoesMesa = DB.load("eleicoesMesa")

/* ========================================================= */
/* PARTIDOS                                                  */
/* ========================================================= */

function criarPartido(){

let nome = document.getElementById("partidoNome").value
let sigla = document.getElementById("partidoSigla").value
let cor = document.getElementById("partidoCor").value

let partido = {

id:Date.now(),
nome,
sigla,
cor,
membros:[]

}

partidos.push(partido)
DB.save("partidos",partidos)

renderPartidos()

}

function entrarPartido(partidoID){

if(!usuarioAtual) return

let partido = partidos.find(p=>p.id===partidoID)

if(!partido) return

if(!partido.membros.includes(usuarioAtual.id)){
partido.membros.push(usuarioAtual.id)
}

usuarioAtual.partido = partidoID

DB.save("partidos",partidos)
DB.save("contas",contas)

renderPartidos()

}

function renderPartidos(){

let el=document.getElementById("listaPartidos")
if(!el) return

el.innerHTML=""

partidos.forEach(p=>{

el.innerHTML+=`

<div class="card">

<strong style="color:${p.cor}">${p.sigla}</strong>
<br>
${p.nome}

<br><br>

Membros: ${p.membros.length}

<br>

<button onclick="entrarPartido(${p.id})">Entrar</button>

</div>

`

})

}

/* ========================================================= */
/* BANCADAS                                                  */
/* ========================================================= */

function calcularBancadas(){

bancadas=[]

partidos.forEach(p=>{

let deputados = p.membros.filter(id=>{
let u = parlamentares.find(x=>x.id===id)
return u && u.cargo==="deputado"
})

let senadores = p.membros.filter(id=>{
let u = parlamentares.find(x=>x.id===id)
return u && u.cargo==="senador"
})

bancadas.push({

partido:p.id,
deputados:deputados.length,
senadores:senadores.length,
total:deputados.length+senadores.length

})

})

DB.save("bancadas",bancadas)

}

/* ========================================================= */
/* ELEIÇÃO MESA DIRETORA                                     */
/* ========================================================= */

function iniciarEleicaoMesa(){

if(usuarioAtual.role!=="admin" && usuarioAtual.role!=="deputado") return

let eleicao = {

id:Date.now(),
candidatos:[],
votos:[],
aberta:true

}

eleicoesMesa.push(eleicao)

DB.save("eleicoesMesa",eleicoesMesa)

renderEleicaoMesa()

}

function candidatarMesa(){

let eleicao = eleicoesMesa[eleicoesMesa.length-1]

if(!eleicao) return

eleicao.candidatos.push(usuarioAtual.id)

DB.save("eleicoesMesa",eleicoesMesa)

renderEleicaoMesa()

}

function votarMesa(id){

let eleicao = eleicoesMesa[eleicoesMesa.length-1]

eleicao.votos.push({

eleitor:usuarioAtual.id,
candidato:id

})

DB.save("eleicoesMesa",eleicoesMesa)

renderEleicaoMesa()

}

function encerrarEleicaoMesa(){

let eleicao = eleicoesMesa[eleicoesMesa.length-1]

let contagem={}

eleicao.votos.forEach(v=>{

contagem[v.candidato]=(contagem[v.candidato]||0)+1

})

let vencedor = Object.keys(contagem).sort((a,b)=>contagem[b]-contagem[a])[0]

mesaDiretora=[{

cargo:"Presidente",
usuario:parseInt(vencedor)

}]

DB.save("mesaDiretora",mesaDiretora)

}

function renderEleicaoMesa(){

let el=document.getElementById("eleicaoMesa")
if(!el) return

let eleicao = eleicoesMesa[eleicoesMesa.length-1]
if(!eleicao) return

el.innerHTML=""

eleicao.candidatos.forEach(id=>{

el.innerHTML+=`

<div class="card">

${buscarNome(id)}

<button onclick="votarMesa(${id})">Votar</button>

</div>

`

})

}

/* ========================================================= */
/* DEFINIR CARGOS DA MESA                                    */
/* ========================================================= */

function definirCargoMesa(usuarioID,cargo){

let existente = mesaDiretora.find(x=>x.cargo===cargo)

if(existente){

existente.usuario=usuarioID

}else{

mesaDiretora.push({
cargo,
usuario:usuarioID
})

}

DB.save("mesaDiretora",mesaDiretora)

}

function renderMesa(){

let el=document.getElementById("listaMesa")
if(!el) return

el.innerHTML=""

mesaDiretora.forEach(m=>{

el.innerHTML+=`

<div class="card">

<strong>${m.cargo}</strong>

<br>

${buscarNome(m.usuario)}

</div>

`

})

}

/* ========================================================= */
/* PAINEL DE VOTAÇÃO AO VIVO                                 */
/* ========================================================= */

function painelVotacao(projetoID){

let painel=document.getElementById("painelVotacao")

let votosProjeto=votos.filter(v=>v.projeto===projetoID)

let sim=votosProjeto.filter(v=>v.voto==="SIM").length
let nao=votosProjeto.filter(v=>v.voto==="NAO").length
let abs=votosProjeto.filter(v=>v.voto==="ABS").length

painel.innerHTML=`

<div class="card">

<h2>Painel de Votação</h2>

SIM: ${sim}

<br>

NÃO: ${nao}

<br>

ABSTENÇÃO: ${abs}

</div>

`

}

/* ========================================================= */
/* VOTOS POR PARLAMENTAR                                     */
/* ========================================================= */

function listarVotosProjeto(projetoID){

let el=document.getElementById("listaVotos")

let votosProjeto=votos.filter(v=>v.projeto===projetoID)

el.innerHTML=""

votosProjeto.forEach(v=>{

el.innerHTML+=`

<div class="card">

${buscarNome(v.usuario)} — ${v.voto}

</div>

`

})

}

/* ========================================================= */
/* ESTATÍSTICAS PARLAMENTARES                                */
/* ========================================================= */

function estatisticasParlamentar(id){

let p = parlamentares.find(x=>x.id===id)

let projetosAutor = projetos.filter(pr=>pr.autor===id).length

let votosPar = votos.filter(v=>v.usuario===id).length

let presencasPar = presencas.filter(p=>p.usuario===id).length

return {

projetos:projetosAutor,
votos:votosPar,
presencas:presencasPar

}

}

function renderEstatisticas(){

let el=document.getElementById("estatisticas")

if(!el) return

el.innerHTML=""

parlamentares.forEach(p=>{

let e = estatisticasParlamentar(p.id)

el.innerHTML+=`

<div class="card">

<strong>${p.nome}</strong>

<br>

Projetos apresentados: ${e.projetos}

<br>

Votos realizados: ${e.votos}

<br>

Presenças: ${e.presencas}

</div>

`

})

}

/* ========================================================= */
/* NOTIFICAÇÕES                                              */
/* ========================================================= */

function notificar(texto){

let n={

id:Date.now(),
texto,
data:new Date().toLocaleString()

}

notificacoes.push(n)

DB.save("notificacoes",notificacoes)

renderNotificacoes()

}

function renderNotificacoes(){

let el=document.getElementById("notificacoes")

if(!el) return

el.innerHTML=""

notificacoes.slice().reverse().forEach(n=>{

el.innerHTML+=`

<div class="card">

${n.texto}

<br>

<small>${n.data}</small>

</div>

`

})

}

/* ========================================================= */
/* CONVOCAÇÃO DE SESSÃO                                      */
/* ========================================================= */

function convocarSessao(){

let titulo=document.getElementById("convTitulo").value

notificar("Sessão convocada: "+titulo)

criarSessao()

}

/* ========================================================= */
/* MENÇÕES @ E PROJETOS #                                    */
/* ========================================================= */

function processarTexto(texto){

contas.forEach(u=>{

texto = texto.replace("@"+u.user,
`<span class="tag">@${u.user}</span>`)

})

projetos.forEach(p=>{

texto = texto.replace("#"+p.id,
`<a href="#" onclick="abrirProjeto(${p.id})">#Projeto${p.id}</a>`)

})

return texto

}

